---
import Layout from "../layouts/Layout.astro";
import ThreeLinePoemActivity from "../components/ThreeLinePoemActivity.astro";
---

<Layout title="三行情书写" description="沉浸式三行情书写活动页，保留原配色并升级评论体验。">
	<main class="immersive-page-shell">
		<ThreeLinePoemActivity />
	</main>
</Layout>

<style>
	.immersive-page-shell {
		position: relative;
		padding: clamp(5.5rem, 8vw, 7rem) clamp(0.5rem, 2vw, 1.25rem) 2rem;
		min-height: 100vh;
		background:
			radial-gradient(circle at top, color-mix(in oklab, var(--primary) 10%, transparent) 0, transparent 32%),
			linear-gradient(180deg, color-mix(in oklab, var(--page-bg) 82%, var(--card-bg) 18%) 0%, var(--page-bg) 100%);
	}
</style>
