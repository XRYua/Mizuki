---
import MainGridLayout from "../layouts/MainGridLayout.astro";
import ThreeLinePoemActivity from "../components/ThreeLinePoemActivity.astro";
---

<MainGridLayout>
	<section class="card-base p-4 mb-4 onload-animation">
		<p class="text-sm text-[var(--primary)] font-bold m-0">活动页</p>
		<h1 class="mt-1 mb-2 text-2xl font-bold">三行情书写</h1>
		<p class="m-0">在这里留下三行短句，所有访客都可以浏览、点赞，并按热度进入排行。</p>
	</section>
	<ThreeLinePoemActivity />
</MainGridLayout>
