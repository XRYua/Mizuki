---
import { commentConfig } from "@/config";

const twikooConfig = {
	...commentConfig.twikoo,
	el: "#three-line-twikoo",
	path: "/three-line-poem",
};
---

<section class="three-line-poem-activity onload-animation">
	<div class="activity-orb activity-orb-left"></div>
	<div class="activity-orb activity-orb-center"></div>
	<div class="activity-orb activity-orb-right"></div>
	<div class="activity-stars" aria-hidden="true"></div>

	<header class="activity-header">
		<p class="activity-eyebrow">三行情书写 · 沉浸留言场</p>
		<h1>把今夜想说的话，写成三行。</h1>
		<p class="activity-lead">
			你可以在这里写下一句给自己，一句给远方，一句给还没说出口的心事；
			也可以把月色、晚风、想念与迟到的晚安，轻轻留在这面会发光的留言墙里。
		</p>
		<p class="activity-subline">
			愿每个路过的人，都能在别人的三行里，看见自己某一刻没有说完的情绪。
		</p>
	</header>

	<div class="activity-note">
		<p>
			今夜把词句借给风吧：写一小段星光，写一口迟到的晚安，写一封没寄出的心事。
			你不必写得盛大，三行就够；真诚落笔，已经很动人。
		</p>
	</div>

	<div class="activity-scene">
		<div class="scene-quote scene-quote-left">“写给自己”</div>
		<div class="scene-quote scene-quote-right">“写给远方”</div>
		<div class="scene-line-grid" aria-label="三行情书灵感提示">
			<span>今夜想对谁说一句晚安？</span>
			<span>哪一句心事，你一直没寄出去？</span>
			<span>如果只能写三行，你最想留下什么？</span>
		</div>
	</div>

	<div class="activity-board">
		<div class="board-head">
			<div class="board-heading">
				<p class="board-kicker">匿名也温柔，署名也浪漫</p>
				<h2 class="board-title">💌 三行情书留言墙</h2>
				<p class="board-description">
					使用昵称与邮箱标识后即可落笔，也可以给喜欢的字句点一个赞；
					让每一段三行情书，都被认真看见、被温柔停留。
				</p>
			</div>
		</div>
		<div class="board-shell">
			<div class="board-shell-glow"></div>
			<div class="board-shell-highlight"></div>
			<div id="three-line-twikoo" class="twikoo-host"></div>
		</div>
	</div>

	<footer class="activity-ending">
		<p>愿每一封情书都不落空，愿每一个深夜写下的名字，最终都有回音。</p>
	</footer>
</section>

<script is:inline src="/scroll-protection.js"></script>
<script is:inline src="/assets/js/twikoo.all.min.js"></script>
<script is:inline define:vars={{ twikooConfig }}>
	function initThreeLineTwikoo() {
		if (typeof twikoo === "undefined") {
			setTimeout(initThreeLineTwikoo, 400);
			return;
		}

		const host = document.getElementById("three-line-twikoo");
		if (!host) return;
		host.innerHTML = "";
		twikoo
			.init({
				...twikooConfig,
				el: "#three-line-twikoo",
				path: "/three-line-poem",
			})
			.catch((error) => {
				console.error("[ThreeLinePoem] Twikoo 初始化失败", error);
			});
	}

	document.addEventListener("DOMContentLoaded", initThreeLineTwikoo);
	if (window.swup?.hooks) {
		window.swup.hooks.on("content:replace", () => {
			setTimeout(initThreeLineTwikoo, 200);
		});
	}
</script>

<style>
	.three-line-poem-activity {
		position: relative;
		overflow: hidden;
		padding: clamp(1.2rem, 2vw, 2rem);
		border: 1px solid rgba(196, 181, 253, 0.28);
		border-radius: 2rem;
		background:
			radial-gradient(circle at top left, rgba(167, 139, 250, 0.34) 0, transparent 34%),
			radial-gradient(circle at 80% 10%, rgba(244, 114, 182, 0.22) 0, transparent 24%),
			radial-gradient(circle at 50% 100%, rgba(125, 211, 252, 0.14) 0, transparent 34%),
			linear-gradient(145deg, rgba(76, 29, 149, 0.42) 0%, rgba(91, 33, 182, 0.28) 32%, rgba(139, 92, 246, 0.18) 58%, rgba(255, 255, 255, 0.12) 100%);
		box-shadow:
			0 32px 80px rgba(49, 24, 91, 0.28),
			inset 0 1px 0 rgba(255, 255, 255, 0.22),
			inset 0 -1px 0 rgba(196, 181, 253, 0.18);
		backdrop-filter: blur(22px) saturate(140%);
		isolation: isolate;
	}

	.activity-stars {
		position: absolute;
		inset: 0;
		background-image:
			radial-gradient(circle at 18% 22%, rgba(255, 255, 255, 0.8) 0 2px, transparent 2.5px),
			radial-gradient(circle at 74% 18%, rgba(255, 255, 255, 0.65) 0 1.5px, transparent 2px),
			radial-gradient(circle at 82% 36%, rgba(255, 255, 255, 0.5) 0 1.5px, transparent 2px),
			radial-gradient(circle at 34% 78%, rgba(255, 255, 255, 0.42) 0 1.5px, transparent 2px);
		opacity: 0.8;
		pointer-events: none;
	}

	.activity-orb {
		position: absolute;
		z-index: -1;
		border-radius: 999px;
		filter: blur(14px);
		opacity: 0.75;
	}

	.activity-orb-left {
		width: 12rem;
		height: 12rem;
		top: -4rem;
		left: -3rem;
		background: color-mix(in oklab, var(--primary) 28%, transparent);
	}

	.activity-orb-center {
		width: 14rem;
		height: 14rem;
		top: 28%;
		left: 46%;
		transform: translate(-50%, -50%);
		background: color-mix(in oklab, #f9a8d4 18%, transparent);
	}

	.activity-orb-right {
		width: 11rem;
		height: 11rem;
		bottom: 1rem;
		right: -2rem;
		background: color-mix(in oklab, #60a5fa 18%, transparent);
	}

	.activity-header {
		position: relative;
		padding: 0.35rem 0 0;
	}

	.activity-eyebrow {
		display: inline-flex;
		align-items: center;
		margin: 0;
		padding: 0.42rem 0.78rem;
		border: 1px solid rgba(196, 181, 253, 0.34);
		border-radius: 999px;
		background: linear-gradient(135deg, rgba(109, 40, 217, 0.28), rgba(255, 255, 255, 0.08));
		color: color-mix(in oklab, white 22%, var(--primary) 78%);
		font-size: 0.82rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		backdrop-filter: blur(8px);
	}

	.activity-header h1 {
		margin: 0.9rem 0 0.7rem;
		font-size: clamp(2rem, 5vw, 3.6rem);
		line-height: 1.08;
		letter-spacing: 0.04em;
		text-shadow: 0 10px 30px rgba(15, 23, 42, 0.12);
	}

	.activity-lead,
	.activity-subline {
		max-width: 56rem;
		margin: 0;
		line-height: 1.95;
		font-size: 1rem;
		color: color-mix(in oklab, var(--text-normal) 90%, white 10%);
	}

	.activity-subline {
		margin-top: 0.65rem;
		color: color-mix(in oklab, var(--text-normal) 72%, var(--primary) 28%);
	}

	.activity-note {
		position: relative;
		margin-top: 1.2rem;
		padding: 1rem 1.1rem;
		border: 1px solid rgba(196, 181, 253, 0.22);
		border-radius: 1.25rem;
		background: linear-gradient(135deg, rgba(109, 40, 217, 0.18), rgba(255, 255, 255, 0.08));
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.28),
			0 20px 40px rgba(49, 24, 91, 0.16);
		backdrop-filter: blur(14px) saturate(125%);
	}

	.activity-note p {
		margin: 0;
		line-height: 1.9;
		font-size: 0.98rem;
	}

	.activity-scene {
		position: relative;
		display: grid;
		gap: 0.85rem;
		margin-top: 1.15rem;
		padding: 1.05rem;
		border: 1px solid rgba(196, 181, 253, 0.22);
		border-radius: 1.4rem;
		background: linear-gradient(135deg, rgba(76, 29, 149, 0.22), rgba(255, 255, 255, 0.08));
		backdrop-filter: blur(14px) saturate(125%);
	}

	.scene-line-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.8rem;
	}

	.scene-line-grid span,
	.scene-quote {
		padding: 0.8rem 0.95rem;
		border-radius: 1rem;
		background: linear-gradient(135deg, rgba(109, 40, 217, 0.18), rgba(255, 255, 255, 0.1));
		border: 1px solid rgba(216, 180, 254, 0.22);
		line-height: 1.75;
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.22);
	}

	.scene-quote {
		display: inline-flex;
		width: fit-content;
		font-size: 0.92rem;
		color: color-mix(in oklab, var(--text-normal) 75%, var(--primary) 25%);
	}

	.scene-quote-right {
		justify-self: end;
	}

	.activity-board {
		position: relative;
		margin-top: 1.25rem;
	}

	.board-head {
		margin-bottom: 1rem;
	}

	.board-heading {
		padding: 0.2rem 0.1rem 0;
	}

	.board-kicker {
		margin: 0;
		font-size: 0.82rem;
		font-weight: 800;
		letter-spacing: 0.12em;
		color: color-mix(in oklab, var(--text-normal) 65%, var(--primary) 35%);
	}

	.board-title {
		margin: 0.5rem 0 0;
		font-size: clamp(1.4rem, 2vw, 2rem);
		font-weight: 800;
	}

	.board-description {
		max-width: 48rem;
		margin: 0.65rem 0 0;
		line-height: 1.9;
		color: color-mix(in oklab, var(--text-normal) 82%, white 18%);
	}

	.board-shell {
		position: relative;
		padding: clamp(0.95rem, 1.6vw, 1.25rem);
		border: 1px solid rgba(196, 181, 253, 0.28);
		border-radius: 1.8rem;
		background:
			linear-gradient(180deg, rgba(88, 28, 135, 0.34), rgba(255, 255, 255, 0.1)),
			radial-gradient(circle at top, rgba(167, 139, 250, 0.22), transparent 58%);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.22),
			0 28px 60px rgba(49, 24, 91, 0.24);
		backdrop-filter: blur(18px) saturate(135%);
	}

	.board-shell-glow,
	.board-shell-highlight {
		position: absolute;
		inset: 0;
		border-radius: inherit;
		pointer-events: none;
	}

	.board-shell-glow {
		background: linear-gradient(135deg, rgba(139, 92, 246, 0.24), transparent 35%, rgba(244, 114, 182, 0.18));
	}

	.board-shell-highlight {
		inset: 1px;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0.02) 26%, transparent 46%);
	}

	.twikoo-host {
		position: relative;
		padding: 0.45rem;
		border-radius: 1.25rem;
		background: linear-gradient(180deg, rgba(91, 33, 182, 0.18), rgba(255, 255, 255, 0.08));
	}

	.twikoo-host :global(.tk-comments-container) {
		margin-top: 1.2rem;
		padding-top: 1.1rem;
		border-top: 1px solid color-mix(in oklab, var(--primary) 12%, transparent);
	}

	.twikoo-host :global(.tk-comments-title) {
		margin-bottom: 0.95rem;
	}

	.twikoo-host :global(.tk-submit) {
		padding: 1rem;
		border: 1px solid rgba(196, 181, 253, 0.18);
		border-radius: 1.2rem;
		background: linear-gradient(180deg, rgba(76, 29, 149, 0.16), rgba(255, 255, 255, 0.16));
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.22),
			0 16px 35px rgba(49, 24, 91, 0.12);
	}

	.twikoo-host :global(.tk-row.actions) {
		margin-top: 0.95rem;
		padding-top: 0.95rem;
		border-top: 1px dashed color-mix(in oklab, var(--primary) 16%, transparent);
	}

	.twikoo-host :global(.tk-meta-input) {
		gap: 0.75rem;
	}

	.twikoo-host :global(.tk-avatar),
	.twikoo-host :global(.tk-avatar img) {
		border-radius: 1rem;
	}

	.twikoo-host :global(.tk-input),
	.twikoo-host :global(.el-input__inner),
	.twikoo-host :global(.el-textarea__inner) {
		border-radius: 1rem !important;
		border-color: rgba(196, 181, 253, 0.22) !important;
		background: rgba(255, 255, 255, 0.82) !important;
		box-shadow: none !important;
		transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
	}

	.twikoo-host :global(.el-input__inner),
	.twikoo-host :global(.el-textarea__inner) {
		padding: 0.9rem 1rem !important;
	}

	.twikoo-host :global(.tk-input:focus),
	.twikoo-host :global(.el-input__inner:focus),
	.twikoo-host :global(.el-textarea__inner:focus) {
		border-color: color-mix(in oklab, var(--primary) 52%, transparent) !important;
		box-shadow: 0 0 0 4px color-mix(in oklab, var(--primary) 12%, transparent) !important;
		transform: translateY(-1px);
	}

	.twikoo-host :global(.tk-preview-container),
	.twikoo-host :global(.tk-comment) {
		border: 1px solid rgba(196, 181, 253, 0.18);
		border-radius: 1.15rem;
		background: linear-gradient(180deg, rgba(76, 29, 149, 0.14), rgba(255, 255, 255, 0.14));
		box-shadow: 0 18px 36px rgba(49, 24, 91, 0.12);
	}

	.twikoo-host :global(.tk-comment) {
		margin-bottom: 0.95rem;
		padding: 0.95rem 1rem;
	}

	.twikoo-host :global(.tk-comment .tk-content) {
		line-height: 1.9;
		font-size: 0.98rem;
	}

	.twikoo-host :global(.tk-tag),
	.twikoo-host :global(.tk-action-icon),
	.twikoo-host :global(.tk-comments-title > span),
	.twikoo-host :global(.tk-icon.__comments) {
		color: color-mix(in oklab, var(--text-normal) 78%, var(--primary) 22%);
	}

	.twikoo-host :global(.tk-extras),
	.twikoo-host :global(.tk-meta) {
		opacity: 0.82;
	}

	.twikoo-host :global(.el-button),
	.twikoo-host :global(.tk-submit-action-icon.__submit),
	.twikoo-host :global(.tk-preview) {
		border-radius: 999px !important;
	}

	.twikoo-host :global(.el-button--primary),
	.twikoo-host :global(.tk-submit-action-icon.__submit),
	.twikoo-host :global(.tk-preview) {
		border: none !important;
		background: linear-gradient(135deg, color-mix(in oklab, var(--primary) 88%, white 12%), color-mix(in oklab, var(--primary) 62%, #f472b6 38%)) !important;
		box-shadow: 0 14px 28px color-mix(in oklab, var(--primary) 20%, transparent);
	}

	.twikoo-host :global(.tk-replies) {
		margin-top: 0.85rem;
		padding-left: 0.8rem;
		border-left: 1px solid color-mix(in oklab, var(--primary) 12%, transparent);
	}

	.twikoo-host :global(.tk-replies .tk-comment) {
		background: linear-gradient(180deg, rgba(109, 40, 217, 0.12), rgba(255, 255, 255, 0.12));
	}

	.activity-ending {
		margin-top: 1.2rem;
		padding-top: 0.25rem;
		text-align: center;
	}

	.activity-ending p {
		margin: 0;
		line-height: 1.85;
		font-weight: 600;
		color: color-mix(in oklab, var(--text-normal) 75%, var(--primary) 25%);
	}

	@media (max-width: 900px) {
		.scene-line-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 768px) {
		.three-line-poem-activity {
			padding: 1rem;
			border-radius: 1.5rem;
		}

		.activity-header h1 {
			font-size: clamp(1.8rem, 10vw, 2.6rem);
		}

		.activity-lead,
		.activity-subline,
		.board-description,
		.activity-note p,
		.scene-line-grid span {
			font-size: 0.96rem;
		}

		.scene-quote-right {
			justify-self: start;
		}

		.board-shell {
			padding: 0.8rem;
			border-radius: 1.35rem;
		}
	}
</style>
