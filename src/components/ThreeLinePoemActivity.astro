---
---

<section class="three-line-poem-activity card-base mb-6 onload-animation">
	<div class="activity-header">
		<p class="activity-eyebrow">✨ 置顶活动</p>
		<h2>三行情书写</h2>
		<p>留下你的三行心事，所有访客都可以查看、点赞和互动。</p>
	</div>

	<form id="three-line-form" class="activity-form">
		<div class="form-row">
			<input id="poem-name" type="text" maxlength="24" placeholder="你的名称" required />
			<input id="poem-email" type="email" maxlength="80" placeholder="邮箱（仅用于标识）" required />
		</div>
		<textarea id="poem-content" rows="4" maxlength="240" placeholder="写下三行（可用换行）" required></textarea>
		<button type="submit" class="btn-primary">发布三行情书</button>
	</form>

	<div class="activity-board">
		<div class="board-title">💌 热门留言榜</div>
		<ul id="poem-list" class="poem-list"></ul>
	</div>
</section>

<script is:inline>
	const STORAGE_KEY = "mizuki-three-line-poems";
	const form = document.getElementById("three-line-form");
	const list = document.getElementById("poem-list");

	function readPoems() {
		try {
			const raw = localStorage.getItem(STORAGE_KEY);
			const parsed = raw ? JSON.parse(raw) : [];
			return Array.isArray(parsed) ? parsed : [];
		} catch {
			return [];
		}
	}

	function savePoems(poems) {
		localStorage.setItem(STORAGE_KEY, JSON.stringify(poems));
	}

	function escapeHtml(text) {
		return text
			.replaceAll("&", "&amp;")
			.replaceAll("<", "&lt;")
			.replaceAll(">", "&gt;")
			.replaceAll('"', "&quot;");
	}

	function maskEmail(email) {
		const [name, domain] = email.split("@");
		if (!name || !domain) return "***";
		return `${name.slice(0, 2)}***@${domain}`;
	}

	function render() {
		const poems = readPoems().sort((a, b) => b.likes - a.likes || b.createdAt - a.createdAt);
		if (!poems.length) {
			list.innerHTML = '<li class="poem-empty">还没有留言，来发布第一封三行情书吧。</li>';
			return;
		}
		list.innerHTML = poems
			.map((item, index) => {
				const content = escapeHtml(item.content).replaceAll("\n", "<br>");
				return `<li class="poem-item" data-id="${item.id}">
					<div class="poem-meta"><span class="rank">#${index + 1}</span><strong>${escapeHtml(item.name)}</strong><span class="email">${maskEmail(item.email)}</span></div>
					<p class="poem-content">${content}</p>
					<button class="like-btn" data-id="${item.id}" type="button">👍 ${item.likes}</button>
				</li>`;
			})
			.join("");
	}

	form?.addEventListener("submit", (event) => {
		event.preventDefault();
		const name = document.getElementById("poem-name")?.value?.trim();
		const email = document.getElementById("poem-email")?.value?.trim();
		const content = document.getElementById("poem-content")?.value?.trim();
		if (!name || !email || !content) return;

		const poems = readPoems();
		poems.push({
			id: crypto.randomUUID(),
			name,
			email,
			content,
			likes: 0,
			createdAt: Date.now(),
		});
		savePoems(poems);
		form.reset();
		render();
	});

	list?.addEventListener("click", (event) => {
		const btn = event.target.closest(".like-btn");
		if (!btn) return;
		const id = btn.getAttribute("data-id");
		const poems = readPoems();
		const target = poems.find((item) => item.id === id);
		if (!target) return;
		target.likes += 1;
		savePoems(poems);
		render();
	});

	render();
</script>

<style>
	.three-line-poem-activity {
		padding: 1.25rem;
		border: 1px solid color-mix(in oklab, var(--primary) 35%, transparent);
		background: linear-gradient(135deg, color-mix(in oklab, var(--primary) 10%, var(--card-bg)) 0%, var(--card-bg) 60%);
	}
	.activity-header h2 { margin: .25rem 0; font-size: 1.4rem; }
	.activity-eyebrow { color: var(--primary); font-weight: 700; margin: 0; }
	.activity-form { display: grid; gap: .75rem; margin-top: .75rem; }
	.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: .75rem; }
	.activity-form input, .activity-form textarea {
		width: 100%; border: 1px solid var(--line-divider); border-radius: .65rem; padding: .65rem .75rem; background: var(--card-bg); color: var(--text-normal);
	}
	.activity-board { margin-top: 1rem; }
	.poem-list { list-style: none; padding: 0; margin: .5rem 0 0; display: grid; gap: .65rem; }
	.poem-item { border: 1px solid var(--line-divider); border-radius: .65rem; padding: .7rem .8rem; background: color-mix(in oklab, var(--card-bg) 92%, var(--primary) 8%); }
	.poem-meta { display:flex; align-items:center; gap:.5rem; font-size:.88rem; }
	.rank { color: var(--primary); font-weight: 700; }
	.email { margin-left:auto; opacity:.7; font-size:.8rem; }
	.poem-content { margin: .5rem 0; line-height: 1.8; }
	.like-btn { border: 1px solid var(--line-divider); border-radius: 999px; padding: .25rem .65rem; background: transparent; cursor: pointer; }
	.poem-empty { opacity: .8; padding: .8rem; border: 1px dashed var(--line-divider); border-radius: .65rem; }
	@media (max-width: 768px){ .form-row{ grid-template-columns: 1fr; } }
</style>
