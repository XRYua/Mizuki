---
import { commentConfig } from "@/config";

const twikooConfig = {
	...commentConfig.twikoo,
	el: "#three-line-twikoo",
	path: "/three-line-poem",
};
---

<section class="three-line-poem-activity onload-animation">
	<div class="activity-liquid activity-liquid-a"></div>
	<div class="activity-liquid activity-liquid-b"></div>
	<div class="activity-liquid activity-liquid-c"></div>
	<div class="activity-orb activity-orb-left"></div>
	<div class="activity-orb activity-orb-center"></div>
	<div class="activity-orb activity-orb-right"></div>
	<div class="activity-stars" aria-hidden="true"></div>

	<header class="activity-header">
		<p class="activity-eyebrow">三行情书写 · 淡紫渐变蓝液态玻璃留言场</p>
		<h1>把心动、想念和晚安，写成会发光的三行。</h1>
		<p class="activity-lead">
			这里不只是一个评论区，而是一面适合停下来、慢慢落笔的液态玻璃信笺墙。
			你可以写一句给自己，一句给远方，一句给还没说出口的心事；也可以把月光、海风、想念与迟到的晚安，轻轻留在这里。
		</p>
		<p class="activity-subline">
			每一条留言都像一封短小却真诚的信，会被人读到、回应、点赞，也会在某个深夜，刚好治愈另一个人。
		</p>
	</header>

	<div class="activity-floating-grid" aria-label="活动亮点">
		<div class="floating-card">
			<span class="floating-label">液态氛围</span>
			<strong>淡紫、浅蓝、柔粉交叠成流动玻璃</strong>
			<p>不是普通留言板，而是一块带雾感高光、漂浮倒影与夜色流光的沉浸式信笺场。</p>
		</div>
		<div class="floating-card">
			<span class="floating-label">互动方式</span>
			<strong>写下三行，也能点赞、回应、收藏此刻心情</strong>
			<p>每一个来访者都可以留下自己的三行，也可以在别人的字句里找到共鸣与停留。</p>
		</div>
	</div>

	<div class="activity-note glass-panel">
		<p>
			今夜把词句借给风吧：写一小段星光，写一口迟到的晚安，写一封没寄出的心事。
			你不必写得盛大，三行就够；只要真诚落笔，这三行就会比长篇更动人。
		</p>
	</div>

	<div class="activity-tools glass-panel" aria-label="快速灵感工具">
		<div class="tool-head">
			<div>
				<p class="tool-kicker">可以更好玩一点</p>
				<h2>灵感切换 · 快速落笔 · 随机心动</h2>
			</div>
			<div class="tool-actions">
				<button class="glass-button is-primary" type="button" data-action="random-idea">换一条灵感</button>
				<button class="glass-button" type="button" data-action="scroll-comment">直接去留言</button>
			</div>
		</div>

		<div class="mood-tabs" role="tablist" aria-label="三行情书主题切换">
			<button class="mood-tab is-active" type="button" role="tab" aria-selected="true" data-mood="self">写给自己</button>
			<button class="mood-tab" type="button" role="tab" aria-selected="false" data-mood="distance">写给远方</button>
			<button class="mood-tab" type="button" role="tab" aria-selected="false" data-mood="secret">写给心事</button>
		</div>

		<div class="idea-stage">
			<div class="idea-panel glass-mini-panel">
				<p class="idea-label">当前主题</p>
				<h3 id="idea-title">写给自己</h3>
				<p id="idea-copy" class="idea-copy">把今天没有来得及说给自己的温柔补上：夸夸自己，抱抱自己，也允许自己慢一点。</p>
			</div>
			<div class="idea-panel glass-mini-panel">
				<p class="idea-label">三行示范</p>
				<p id="idea-poem" class="idea-poem">
					今天也辛苦了，<br />
					别急着变成很厉害的人，<br />
					你先好好被自己喜欢。
				</p>
			</div>
			<div class="idea-panel glass-mini-panel idea-panel-cta">
				<p class="idea-label">落笔提示</p>
				<ul class="idea-list">
					<li>第一行写想说给谁</li>
					<li>第二行写最真实的情绪</li>
					<li>第三行写你想留下的回音</li>
				</ul>
				<button class="glass-button is-wide" type="button" data-action="focus-comment">我想立刻写</button>
			</div>
		</div>
	</div>

	<div class="activity-scene glass-panel">
		<div class="scene-quote scene-quote-left">“写给自己”</div>
		<div class="scene-quote scene-quote-right">“写给远方”</div>
		<div class="scene-line-grid" aria-label="三行情书灵感提示">
			<span>今夜你最想对谁说一句晚安？</span>
			<span>哪一句想念，你已经在心里写了很多遍？</span>
			<span>如果只能留下三行，你最想让谁记得你此刻的温柔？</span>
		</div>
	</div>

	<div class="activity-board">
		<div class="board-head">
			<div class="board-heading">
				<p class="board-kicker">匿名也温柔，署名也浪漫</p>
				<h2 class="board-title">💌 三行情书液态留言墙</h2>
				<p class="board-description">
					使用昵称与邮箱标识后即可落笔，也可以给喜欢的字句点一个赞、留下一句回应。
					在这面淡紫渐变蓝的液态玻璃墙里，每一段三行情书都会被认真看见、被温柔停留，也许还会刚好击中另一个人的心。
				</p>
			</div>
			<div class="board-pills" aria-label="活动特性">
				<span>液态玻璃</span>
				<span>三行短诗</span>
				<span>公开互动</span>
			</div>
		</div>
		<div class="board-shell">
			<div class="board-shell-glow"></div>
			<div class="board-shell-highlight"></div>
			<div class="board-shell-blur"></div>
			<div class="comment-helper glass-mini-panel">
				<div class="comment-helper-head">
					<div>
						<p class="idea-label">快捷写作</p>
						<h3>一键插入更好写</h3>
					</div>
					<button class="glass-button" type="button" data-action="focus-comment">展开输入框</button>
				</div>
				<div class="comment-helper-pills">
					<button class="helper-pill" type="button" data-insert-template="开头">想把今天的心情写给你，</button>
					<button class="helper-pill" type="button" data-insert-template="晚安">今晚的月色很安静，</button>
					<button class="helper-pill" type="button" data-insert-template="想念">原来想念也会发光，</button>
					<button class="helper-pill" type="button" data-insert-template="结尾">愿你读到时，刚好温柔。</button>
				</div>
			</div>
			<div id="three-line-twikoo" class="twikoo-host"></div>
		</div>
	</div>

	<footer class="activity-ending glass-panel">
		<p>
			愿每一封情书都不落空，愿每一个深夜写下的名字，最终都有回音；
			愿你写下的三行，不只被看见，也被轻轻珍藏。
		</p>
	</footer>
</section>

<script is:inline src="/scroll-protection.js"></script>
<script is:inline src="/assets/js/twikoo.all.min.js"></script>
<script is:inline define:vars={{ twikooConfig }}>
	const commentTemplates = {
		开头: "想把今天的心情写给你，\n这里是第一行。\n这里是第二行。\n这里是第三行。",
		晚安: "今晚的月色很安静，\n我想把迟到的晚安送给你，\n也把温柔留在这里。",
		想念: "原来想念也会发光，\n它在每一个没说出口的夜里，\n替我慢慢靠近你。",
		结尾: "愿你读到时，刚好温柔。",
	};

	const poemIdeas = {
		self: {
			title: "写给自己",
			copy: "把今天没有来得及说给自己的温柔补上：夸夸自己，抱抱自己，也允许自己慢一点。",
			poem: ["今天也辛苦了，", "别急着变成很厉害的人，", "你先好好被自己喜欢。"],
		},
		distance: {
			title: "写给远方",
			copy: "给那个暂时不在身边的人写三行风，把想念、牵挂和一句晚安一起寄出去。",
			poem: ["风从你那边吹来时，", "我把没说完的话藏进夜里，", "等下一次见面再轻轻告诉你。"],
		},
		secret: {
			title: "写给心事",
			copy: "如果有一句话一直停在心口，就让它先在这里落地；哪怕不署名，也可以很真诚。",
			poem: ["有些喜欢不必声张，", "它安静地亮在每一个深夜里，", "像月光替我说过一次想你。"],
		},
	};

	function renderIdea(moodKey) {
		const idea = poemIdeas[moodKey];
		const titleEl = document.getElementById("idea-title");
		const copyEl = document.getElementById("idea-copy");
		const poemEl = document.getElementById("idea-poem");
		if (!idea || !titleEl || !copyEl || !poemEl) return;
		titleEl.textContent = idea.title;
		copyEl.textContent = idea.copy;
		poemEl.innerHTML = idea.poem.join("<br />");
		document.querySelectorAll(".mood-tab").forEach((tab) => {
			const isActive = tab.getAttribute("data-mood") === moodKey;
			tab.classList.toggle("is-active", isActive);
			tab.setAttribute("aria-selected", isActive ? "true" : "false");
		});
	}

	function insertTemplateToComment(templateKey) {
		const template = commentTemplates[templateKey];
		if (!template) return;
		const textarea = document.querySelector("#three-line-twikoo textarea, #three-line-twikoo .el-textarea__inner");
		if (!textarea) {
			document.getElementById("three-line-twikoo")?.scrollIntoView({ behavior: "smooth", block: "start" });
			return;
		}
		const currentValue = textarea.value || "";
		textarea.value = currentValue ? `${currentValue}\n${template}` : template;
		textarea.dispatchEvent(new Event("input", { bubbles: true }));
		textarea.focus();
	}

	function bindPoemInteractions() {
		document.querySelectorAll(".mood-tab").forEach((tab) => {
			tab.addEventListener("click", () => {
				renderIdea(tab.getAttribute("data-mood") || "self");
			});
		});

		document.querySelectorAll("[data-action='random-idea']").forEach((button) => {
			button.addEventListener("click", () => {
				const keys = Object.keys(poemIdeas);
				const nextKey = keys[Math.floor(Math.random() * keys.length)];
				renderIdea(nextKey);
			});
		});

		const scrollToComment = () => {
			document.getElementById("three-line-twikoo")?.scrollIntoView({ behavior: "smooth", block: "start" });
		};

		document.querySelectorAll("[data-action='scroll-comment'], [data-action='focus-comment']").forEach((button) => {
			button.addEventListener("click", () => {
				scrollToComment();
				setTimeout(() => {
					document.querySelector("#three-line-twikoo textarea, #three-line-twikoo .el-textarea__inner")?.focus();
				}, 450);
			});
		});

		document.querySelectorAll("[data-insert-template]").forEach((button) => {
			button.addEventListener("click", () => {
				document.getElementById("three-line-twikoo")?.scrollIntoView({ behavior: "smooth", block: "start" });
				setTimeout(() => insertTemplateToComment(button.getAttribute("data-insert-template") || "开头"), 420);
			});
		});
	}

	function initThreeLineTwikoo() {
		if (typeof twikoo === "undefined") {
			setTimeout(initThreeLineTwikoo, 400);
			return;
		}

		const host = document.getElementById("three-line-twikoo");
		if (!host) return;
		host.innerHTML = "";
		twikoo
			.init({
				...twikooConfig,
				el: "#three-line-twikoo",
				path: "/three-line-poem",
			})
			.catch((error) => {
				console.error("[ThreeLinePoem] Twikoo 初始化失败", error);
			});
	}

	function initThreeLinePoemPage() {
		renderIdea("self");
		bindPoemInteractions();
		initThreeLineTwikoo();
	}

	document.addEventListener("DOMContentLoaded", initThreeLinePoemPage);
	if (window.swup?.hooks) {
		window.swup.hooks.on("content:replace", () => {
			setTimeout(initThreeLinePoemPage, 200);
		});
	}
</script>

<style>
	.three-line-poem-activity {
		position: relative;
		overflow: hidden;
		padding: clamp(1.2rem, 2vw, 2rem);
		border: 1px solid rgba(216, 180, 254, 0.16);
		border-radius: 2rem;
		background:
			radial-gradient(circle at top left, rgba(196, 181, 253, 0.2) 0, transparent 26%),
			radial-gradient(circle at 88% 12%, rgba(125, 211, 252, 0.16) 0, transparent 22%),
			radial-gradient(circle at 50% 100%, rgba(244, 114, 182, 0.12) 0, transparent 28%),
			linear-gradient(145deg, rgba(255, 255, 255, 0.24) 0%, rgba(196, 181, 253, 0.14) 34%, rgba(125, 211, 252, 0.12) 62%, rgba(255, 255, 255, 0.22) 100%);
		box-shadow:
			0 36px 90px rgba(56, 34, 110, 0.16),
			inset 0 1px 0 rgba(255, 255, 255, 0.42),
			inset 0 -1px 0 rgba(191, 219, 254, 0.14);
		backdrop-filter: blur(24px) saturate(135%);
		isolation: isolate;
	}

	.activity-liquid {
		position: absolute;
		z-index: -1;
		border-radius: 999px;
		filter: blur(12px);
		opacity: 0.9;
	}

	.activity-liquid-a {
		width: 18rem;
		height: 8rem;
		top: 8%;
		right: -4rem;
		background: linear-gradient(135deg, rgba(196, 181, 253, 0.26), rgba(125, 211, 252, 0.1));
		transform: rotate(-12deg);
	}

	.activity-liquid-b {
		width: 15rem;
		height: 7rem;
		bottom: 12%;
		left: -3rem;
		background: linear-gradient(135deg, rgba(125, 211, 252, 0.16), rgba(244, 114, 182, 0.1));
		transform: rotate(10deg);
	}

	.activity-liquid-c {
		width: 10rem;
		height: 10rem;
		top: 35%;
		right: 18%;
		background: radial-gradient(circle, rgba(255, 255, 255, 0.22), rgba(196, 181, 253, 0.1), transparent 68%);
	}

	.activity-stars {
		position: absolute;
		inset: 0;
		background-image:
			radial-gradient(circle at 16% 20%, rgba(255, 255, 255, 0.82) 0 2px, transparent 2.5px),
			radial-gradient(circle at 76% 18%, rgba(255, 255, 255, 0.68) 0 1.5px, transparent 2px),
			radial-gradient(circle at 82% 42%, rgba(191, 219, 254, 0.48) 0 1.5px, transparent 2px),
			radial-gradient(circle at 34% 78%, rgba(255, 255, 255, 0.42) 0 1.5px, transparent 2px);
		opacity: 0.86;
		pointer-events: none;
	}

	.activity-orb {
		position: absolute;
		z-index: -1;
		border-radius: 999px;
		filter: blur(18px);
		opacity: 0.78;
	}

	.activity-orb-left {
		width: 12rem;
		height: 12rem;
		top: -4rem;
		left: -3rem;
		background: rgba(167, 139, 250, 0.28);
	}

	.activity-orb-center {
		width: 16rem;
		height: 16rem;
		top: 26%;
		left: 48%;
		transform: translate(-50%, -50%);
		background: rgba(125, 211, 252, 0.14);
	}

	.activity-orb-right {
		width: 12rem;
		height: 12rem;
		bottom: 1rem;
		right: -2rem;
		background: rgba(244, 114, 182, 0.18);
	}

	.glass-panel,
	.glass-mini-panel {
		border: 1px solid rgba(216, 180, 254, 0.16);
		background: linear-gradient(135deg, rgba(255, 255, 255, 0.18), rgba(196, 181, 253, 0.08), rgba(125, 211, 252, 0.08));
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.2),
			0 24px 46px rgba(56, 34, 110, 0.1);
		backdrop-filter: blur(18px) saturate(128%);
	}

	.activity-header {
		position: relative;
		padding: 0.35rem 0 0;
	}

	.activity-eyebrow {
		display: inline-flex;
		align-items: center;
		margin: 0;
		padding: 0.44rem 0.82rem;
		border: 1px solid rgba(216, 180, 254, 0.28);
		border-radius: 999px;
		background: linear-gradient(135deg, rgba(167, 139, 250, 0.22), rgba(125, 211, 252, 0.12));
		color: color-mix(in oklab, white 20%, var(--primary) 80%);
		font-size: 0.82rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		backdrop-filter: blur(10px);
	}

	.activity-header h1 {
		margin: 0.9rem 0 0.78rem;
		font-size: clamp(2.2rem, 5vw, 4rem);
		line-height: 1.03;
		letter-spacing: 0.04em;
		text-shadow: 0 12px 32px rgba(40, 21, 94, 0.18);
	}

	.activity-lead,
	.activity-subline {
		max-width: 60rem;
		margin: 0;
		line-height: 2;
		font-size: 1.02rem;
		color: color-mix(in oklab, var(--text-normal) 92%, white 8%);
	}

	.activity-subline {
		margin-top: 0.72rem;
		color: color-mix(in oklab, var(--text-normal) 72%, rgb(147 197 253) 28%);
	}

	.activity-floating-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.95rem;
		margin-top: 1.15rem;
	}

	.floating-card {
		padding: 1rem 1.05rem;
		border-radius: 1.35rem;
		border: 1px solid rgba(216, 180, 254, 0.18);
		background: linear-gradient(135deg, rgba(255, 255, 255, 0.16), rgba(196, 181, 253, 0.08), rgba(125, 211, 252, 0.08));
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.2),
			0 24px 42px rgba(56, 34, 110, 0.16);
		backdrop-filter: blur(16px) saturate(135%);
	}

	.floating-label {
		display: inline-flex;
		margin-bottom: 0.5rem;
		font-size: 0.74rem;
		font-weight: 800;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: color-mix(in oklab, rgb(191 219 254) 40%, var(--primary) 60%);
	}

	.floating-card strong {
		display: block;
		font-size: 1.03rem;
		line-height: 1.7;
	}

	.floating-card p {
		margin: 0.55rem 0 0;
		line-height: 1.85;
		opacity: 0.9;
	}

	.activity-note,
	.activity-tools,
	.activity-scene,
	.activity-ending {
		position: relative;
		margin-top: 1.2rem;
		padding: 1.05rem 1.15rem;
		border-radius: 1.4rem;
	}

	.activity-note p,
	.activity-ending p {
		margin: 0;
		line-height: 1.95;
		font-size: 1rem;
	}

	.tool-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.tool-kicker {
		margin: 0;
		font-size: 0.76rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		font-weight: 800;
		color: color-mix(in oklab, rgb(191 219 254) 40%, var(--primary) 60%);
	}

	.tool-head h2 {
		margin: 0.38rem 0 0;
		font-size: clamp(1.25rem, 2vw, 1.8rem);
	}

	.tool-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.glass-button {
		appearance: none;
		border: 1px solid rgba(216, 180, 254, 0.24);
		border-radius: 999px;
		padding: 0.72rem 1.05rem;
		background: linear-gradient(135deg, rgba(255, 255, 255, 0.2), rgba(196, 181, 253, 0.08));
		color: var(--text-normal);
		font: inherit;
		font-weight: 700;
		cursor: pointer;
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.18),
			0 12px 24px rgba(56, 34, 110, 0.14);
		transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
	}

	.glass-button:hover {
		transform: translateY(-2px);
		border-color: rgba(191, 219, 254, 0.3);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.24),
			0 16px 28px rgba(56, 34, 110, 0.18);
	}

	.glass-button.is-primary,
	.glass-button.is-wide,
	.twikoo-host :global(.el-button--primary),
	.twikoo-host :global(.tk-submit-action-icon.__submit),
	.twikoo-host :global(.tk-preview) {
		background: linear-gradient(135deg, rgba(147, 197, 253, 0.85), rgba(167, 139, 250, 0.95), rgba(244, 114, 182, 0.8)) !important;
		color: white !important;
	}

	.glass-button.is-wide {
		width: 100%;
		justify-content: center;
	}

	.mood-tabs {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem;
		margin-top: 1rem;
	}

	.mood-tab {
		appearance: none;
		border: 1px solid rgba(216, 180, 254, 0.16);
