---
import { commentConfig } from "@/config";

const twikooConfig = {
	...commentConfig.twikoo,
	el: "#three-line-twikoo",
	path: "/three-line-poem",
};
---

<section class="three-line-poem-activity card-base mb-6 onload-animation">
	<div class="activity-orb activity-orb-left"></div>
	<div class="activity-orb activity-orb-right"></div>

	<div class="activity-header">
		<p class="activity-eyebrow">✨ 置顶活动</p>
		<h2>三行情书写</h2>
		<p>你可以在这里写下三行：一句给自己，一句给远方，一句给还没说出口的心事。</p>
	</div>

	<div class="activity-note">
		<p>今夜把词句借给风吧：写一小段星光，写一口迟到的晚安，写一封没寄出的心事。</p>
	</div>

	<div class="activity-meta-grid" aria-label="活动信息卡片">
		<div class="meta-card">
			<span class="meta-label">Atmosphere</span>
			<strong>月光信笺 · 柔焦留言墙</strong>
			<p>将评论输入区重塑成带有玻璃高光与诗意边框的独立展示区。</p>
		</div>
		<div class="meta-card">
			<span class="meta-label">Interaction</span>
			<strong>聚焦写作 · 轻提示引导</strong>
			<p>让昵称、邮箱、内容与按钮层级更清晰，阅读和互动更沉浸。</p>
		</div>
	</div>

	<div class="activity-board">
		<div class="board-head">
			<div>
				<p class="board-kicker">Twikoo Guestbook</p>
				<div class="board-title">💌 活动留言墙</div>
			</div>
			<span class="board-badge">Custom Styled</span>
		</div>
		<p class="board-tip">使用昵称 + 邮箱标识后即可落笔，也可以给喜欢的字句点一个赞。</p>
		<div class="board-shell">
			<div class="board-shell-glow"></div>
			<div id="three-line-twikoo" class="twikoo-host"></div>
		</div>
	</div>

	<p class="activity-ending">愿每一封情，都能被温柔读到。</p>
</section>

<script is:inline src="/scroll-protection.js"></script>
<script is:inline src="/assets/js/twikoo.all.min.js"></script>
<script is:inline define:vars={{ twikooConfig }}>
	function initThreeLineTwikoo() {
		if (typeof twikoo === "undefined") {
			setTimeout(initThreeLineTwikoo, 400);
			return;
		}

		const host = document.getElementById("three-line-twikoo");
		if (!host) return;
		host.innerHTML = "";
		twikoo
			.init({
				...twikooConfig,
				el: "#three-line-twikoo",
				path: "/three-line-poem",
			})
			.catch((error) => {
				console.error("[ThreeLinePoem] Twikoo 初始化失败", error);
			});
	}

	document.addEventListener("DOMContentLoaded", initThreeLineTwikoo);
	if (window.swup?.hooks) {
		window.swup.hooks.on("content:replace", () => {
			setTimeout(initThreeLineTwikoo, 200);
		});
	}
</script>

<style>
	.three-line-poem-activity {
		position: relative;
		overflow: hidden;
		padding: 1.4rem;
		border: 1px solid color-mix(in oklab, var(--primary) 30%, transparent);
		border-radius: 1.5rem;
		background:
			radial-gradient(circle at top left, color-mix(in oklab, var(--primary) 18%, transparent) 0, transparent 42%),
			radial-gradient(circle at 85% 15%, color-mix(in oklab, #f472b6 20%, transparent) 0, transparent 28%),
			linear-gradient(145deg, color-mix(in oklab, var(--primary) 12%, var(--card-bg)) 0%, color-mix(in oklab, var(--card-bg) 94%, white 6%) 55%, color-mix(in oklab, var(--card-bg) 90%, var(--primary) 10%) 100%);
		box-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
		isolation: isolate;
	}

	.activity-orb {
		position: absolute;
		z-index: -1;
		border-radius: 999px;
		filter: blur(10px);
		opacity: 0.7;
	}

	.activity-orb-left {
		width: 10rem;
		height: 10rem;
		top: -3rem;
		left: -2rem;
		background: color-mix(in oklab, var(--primary) 28%, transparent);
	}

	.activity-orb-right {
		width: 8rem;
		height: 8rem;
		bottom: 2rem;
		right: -1.5rem;
		background: color-mix(in oklab, #f472b6 28%, transparent);
	}

	.activity-header h2 {
		margin: 0.25rem 0;
		font-size: clamp(1.5rem, 2vw, 1.95rem);
		letter-spacing: 0.03em;
	}

	.activity-header > p:last-child {
		max-width: 42rem;
		margin: 0;
		line-height: 1.85;
		color: color-mix(in oklab, var(--text-normal) 88%, white 12%);
	}

	.activity-eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		margin: 0;
		padding: 0.38rem 0.72rem;
		border: 1px solid color-mix(in oklab, var(--primary) 30%, transparent);
		border-radius: 999px;
		background: color-mix(in oklab, var(--primary) 10%, transparent);
		color: var(--primary);
		font-size: 0.82rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.activity-note {
		margin-top: 1rem;
		padding: 0.95rem 1rem;
		border: 1px solid color-mix(in oklab, var(--primary) 22%, transparent);
		border-radius: 1rem;
		background: linear-gradient(135deg, color-mix(in oklab, var(--card-bg) 92%, var(--primary) 8%) 0%, color-mix(in oklab, var(--card-bg) 82%, white 18%) 100%);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.32);
		backdrop-filter: blur(8px);
	}

	.activity-note p {
		margin: 0;
		opacity: 0.92;
		line-height: 1.9;
	}

	.activity-meta-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.9rem;
		margin-top: 1rem;
	}

	.meta-card {
		padding: 1rem;
		border: 1px solid color-mix(in oklab, var(--primary) 18%, transparent);
		border-radius: 1.1rem;
		background: color-mix(in oklab, var(--card-bg) 88%, white 12%);
		box-shadow: 0 18px 36px rgba(15, 23, 42, 0.08);
	}

	.meta-label {
		display: block;
		margin-bottom: 0.45rem;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: color-mix(in oklab, var(--text-muted) 85%, var(--primary) 15%);
	}

	.meta-card strong {
		display: block;
		font-size: 1rem;
	}

	.meta-card p {
		margin: 0.55rem 0 0;
		font-size: 0.92rem;
		line-height: 1.7;
		opacity: 0.85;
	}

	.activity-board {
		margin-top: 1.15rem;
	}

	.board-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
	}

	.board-kicker {
		margin: 0 0 0.28rem;
		font-size: 0.75rem;
		font-weight: 800;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: color-mix(in oklab, var(--text-muted) 78%, var(--primary) 22%);
	}

	.board-title {
		font-size: 1.18rem;
		font-weight: 800;
	}

	.board-badge {
		padding: 0.45rem 0.8rem;
		border: 1px solid color-mix(in oklab, var(--primary) 28%, transparent);
		border-radius: 999px;
		background: color-mix(in oklab, var(--primary) 10%, transparent);
		color: var(--primary);
		font-size: 0.78rem;
		font-weight: 800;
		white-space: nowrap;
	}

	.board-tip {
		margin: 0.6rem 0 1rem;
		opacity: 0.8;
		font-size: 0.94rem;
		line-height: 1.75;
	}

	.board-shell {
		position: relative;
		padding: 1rem;
		border: 1px solid color-mix(in oklab, var(--primary) 16%, transparent);
		border-radius: 1.35rem;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.38));
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.65),
			0 20px 40px rgba(15, 23, 42, 0.1);
		backdrop-filter: blur(14px);
	}

	.board-shell-glow {
		position: absolute;
		inset: 0;
		border-radius: inherit;
		background: linear-gradient(135deg, color-mix(in oklab, var(--primary) 8%, transparent), transparent 30%, color-mix(in oklab, #f472b6 12%, transparent));
		pointer-events: none;
	}

	.twikoo-host {
		position: relative;
		padding: 0.35rem;
		border-radius: 1rem;
		background: color-mix(in oklab, var(--card-bg) 86%, white 14%);
	}

	.twikoo-host :global(.tk-comments-container) {
		margin-top: 1rem;
		padding-top: 1rem;
		border-top: 1px solid color-mix(in oklab, var(--primary) 14%, transparent);
	}

	.twikoo-host :global(.tk-submit) {
		padding: 1rem;
		border: 1px solid color-mix(in oklab, var(--primary) 14%, transparent);
		border-radius: 1rem;
		background: linear-gradient(180deg, color-mix(in oklab, white 88%, var(--primary) 12%), color-mix(in oklab, white 94%, var(--card-bg) 6%));
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.7);
	}

	.twikoo-host :global(.tk-row.actions) {
		margin-top: 0.85rem;
		padding-top: 0.85rem;
		border-top: 1px dashed color-mix(in oklab, var(--primary) 16%, transparent);
	}

	.twikoo-host :global(.tk-avatar),
	.twikoo-host :global(.tk-avatar img) {
		border-radius: 1rem;
	}

	.twikoo-host :global(.tk-input),
	.twikoo-host :global(.el-input__inner),
	.twikoo-host :global(.el-textarea__inner) {
		border-radius: 0.9rem !important;
		border-color: color-mix(in oklab, var(--primary) 16%, transparent) !important;
		background: rgba(255, 255, 255, 0.9) !important;
		box-shadow: none !important;
		transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
	}

	.twikoo-host :global(.tk-input:focus),
	.twikoo-host :global(.el-input__inner:focus),
	.twikoo-host :global(.el-textarea__inner:focus) {
		border-color: color-mix(in oklab, var(--primary) 55%, transparent) !important;
		box-shadow: 0 0 0 4px color-mix(in oklab, var(--primary) 14%, transparent) !important;
		transform: translateY(-1px);
	}

	.twikoo-host :global(.tk-preview-container),
	.twikoo-host :global(.tk-comment) {
		border: 1px solid color-mix(in oklab, var(--primary) 14%, transparent);
		border-radius: 1rem;
		background: color-mix(in oklab, white 92%, var(--card-bg) 8%);
		box-shadow: 0 14px 30px rgba(15, 23, 42, 0.06);
	}

	.twikoo-host :global(.tk-comment) {
		padding: 0.85rem 0.95rem;
		margin-bottom: 0.85rem;
	}

	.twikoo-host :global(.tk-comment .tk-content) {
		line-height: 1.85;
		font-size: 0.97rem;
	}

	.twikoo-host :global(.tk-action-icon),
	.twikoo-host :global(.tk-icon.__comments),
	.twikoo-host :global(.tk-comments-title > span) {
		color: color-mix(in oklab, var(--text-normal) 82%, var(--primary) 18%);
	}

	.twikoo-host :global(.tk-extras),
	.twikoo-host :global(.tk-meta) {
		opacity: 0.8;
	}

	.twikoo-host :global(.el-button),
	.twikoo-host :global(.tk-submit-action-icon.__submit) {
		border-radius: 999px !important;
	}

	.twikoo-host :global(.el-button--primary),
	.twikoo-host :global(.tk-preview),
	.twikoo-host :global(.tk-submit-action-icon.__submit) {
		border: none !important;
		background: linear-gradient(135deg, color-mix(in oklab, var(--primary) 88%, white 12%), color-mix(in oklab, var(--primary) 68%, #f472b6 32%)) !important;
		box-shadow: 0 12px 24px color-mix(in oklab, var(--primary) 22%, transparent);
	}

	.twikoo-host :global(.tk-replies .tk-comment) {
		background: color-mix(in oklab, white 86%, var(--primary) 14%);
	}

	.activity-ending {
		margin: 1rem 0 0;
		font-weight: 700;
		letter-spacing: 0.03em;
		color: color-mix(in oklab, var(--text-normal) 78%, var(--primary) 22%);
	}

	@media (max-width: 768px) {
		.three-line-poem-activity {
			padding: 1rem;
			border-radius: 1.2rem;
		}

		.activity-meta-grid {
			grid-template-columns: 1fr;
		}

		.board-head {
			align-items: flex-start;
			flex-direction: column;
		}

		.board-shell {
			padding: 0.8rem;
		}
	}
</style>
