---
import { commentConfig } from "@/config";

const twikooConfig = {
	...commentConfig.twikoo,
	el: "#three-line-twikoo",
	path: "/three-line-poem",
};
---

<section class="three-line-poem-activity card-base mb-6 onload-animation">
	<div class="activity-header">
		<p class="activity-eyebrow">✨ 置顶活动</p>
		<h2>三行情书写</h2>
		<p>留下你的三行心事，所有访客都可以查看、点赞和互动。</p>
	</div>

	<div class="activity-board">
		<div class="board-title">💌 活动留言墙（Twikoo）</div>
		<p class="board-tip">使用昵称 + 邮箱标识后，即可发布三行短句；也可以给喜欢的留言点赞。</p>
		<div id="three-line-twikoo" class="twikoo-host"></div>
	</div>
</section>

<script is:inline src="/scroll-protection.js"></script>
<script is:inline src="/assets/js/twikoo.all.min.js"></script>
<script is:inline define:vars={{ twikooConfig }}>
	function initThreeLineTwikoo() {
		if (typeof twikoo === "undefined") {
			setTimeout(initThreeLineTwikoo, 400);
			return;
		}

		const host = document.getElementById("three-line-twikoo");
		if (!host) return;
		host.innerHTML = "";
		twikoo
			.init({
				...twikooConfig,
				el: "#three-line-twikoo",
				path: "/three-line-poem",
			})
			.catch((error) => {
				console.error("[ThreeLinePoem] Twikoo 初始化失败", error);
			});
	}

	document.addEventListener("DOMContentLoaded", initThreeLineTwikoo);
	if (window.swup?.hooks) {
		window.swup.hooks.on("content:replace", () => {
			setTimeout(initThreeLineTwikoo, 200);
		});
	}
</script>

<style>
	.three-line-poem-activity {
		padding: 1.25rem;
		border: 1px solid color-mix(in oklab, var(--primary) 35%, transparent);
		background: linear-gradient(135deg, color-mix(in oklab, var(--primary) 10%, var(--card-bg)) 0%, var(--card-bg) 60%);
	}
	.activity-header h2 { margin: .25rem 0; font-size: 1.4rem; }
	.activity-eyebrow { color: var(--primary); font-weight: 700; margin: 0; }
	.activity-board { margin-top: 1rem; }
	.board-tip {
		margin: .45rem 0 1rem;
		opacity: .8;
		font-size: .92rem;
	}
	.twikoo-host {
		padding: .25rem;
		border-radius: .75rem;
		background: color-mix(in oklab, var(--card-bg) 94%, var(--primary) 6%);
	}
	.poem-empty { opacity: .8; padding: .8rem; border: 1px dashed var(--line-divider); border-radius: .65rem; }
</style>
