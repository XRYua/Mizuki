---
import { commentConfig } from "@/config";

const twikooConfig = {
	...commentConfig.twikoo,
	el: "#three-line-twikoo",
	path: "/three-line-poem",
};
---

<section class="three-line-poem-activity onload-animation">
	<div class="activity-liquid activity-liquid-a"></div>
	<div class="activity-liquid activity-liquid-b"></div>
	<div class="activity-liquid activity-liquid-c"></div>
	<div class="activity-orb activity-orb-left"></div>
	<div class="activity-orb activity-orb-center"></div>
	<div class="activity-orb activity-orb-right"></div>
	<div class="activity-stars" aria-hidden="true"></div>

	<header class="activity-header">
		<p class="activity-eyebrow">三行情书写 · 淡紫渐变蓝液态玻璃留言场</p>
		<h1>把心动、想念和晚安，写成会发光的三行。</h1>
		<p class="activity-lead">
			这里不只是一个评论区，而是一面适合停下来、慢慢落笔的液态玻璃信笺墙。
			你可以写一句给自己，一句给远方，一句给还没说出口的心事；也可以把月光、海风、想念与迟到的晚安，轻轻留在这里。
		</p>
		<p class="activity-subline">
			每一条留言都像一封短小却真诚的信，会被人读到、回应、点赞，也会在某个深夜，刚好治愈另一个人。
		</p>
	</header>

	<div class="activity-note glass-panel">
		<p>
			今夜把词句借给风吧：写一小段星光，写一口迟到的晚安，写一封没寄出的心事。
			你不必写得盛大，三行就够；只要真诚落笔，这三行就会比长篇更动人。
		</p>
	</div>

	<div class="activity-scene glass-panel">
		<div class="scene-quote scene-quote-left">“写给自己”</div>
		<div class="scene-quote scene-quote-right">“写给远方”</div>
		<div class="scene-line-grid" aria-label="三行情书灵感提示">
			<span>今夜你最想对谁说一句晚安？</span>
			<span>哪一句想念，你已经在心里写了很多遍？</span>
			<span>如果只能留下三行，你最想让谁记得你此刻的温柔？</span>
		</div>
	</div>

	<div class="activity-board">
		<div class="board-head">
			<div class="board-heading">
				<p class="board-kicker">匿名也温柔，署名也浪漫</p>
				<h2 class="board-title">💌 三行情书液态留言墙</h2>
				<p class="board-description">
					使用昵称与邮箱标识后即可落笔，也可以给喜欢的字句点一个赞、留下一句回应。
					在这面淡紫渐变蓝的液态玻璃墙里，每一段三行情书都会被认真看见、被温柔停留，也许还会刚好击中另一个人的心。
				</p>
			</div>
		</div>
		<div class="board-shell">
			<div class="board-shell-glow"></div>
			<div class="board-shell-highlight"></div>
			<div class="board-shell-blur"></div>
			<div id="three-line-twikoo" class="twikoo-host"></div>
		</div>
	</div>

	<footer class="activity-ending glass-panel">
		<p>
			愿每一封情书都不落空，愿每一个深夜写下的名字，最终都有回音；
			愿你写下的三行，不只被看见，也被轻轻珍藏。
		</p>
	</footer>
</section>

<script is:inline src="/scroll-protection.js"></script>
<script is:inline src="/assets/js/twikoo.all.min.js"></script>
<script is:inline define:vars={{ twikooConfig }}>
	function initThreeLineTwikoo() {
		if (typeof twikoo === "undefined") {
			setTimeout(initThreeLineTwikoo, 400);
			return;
		}

		const host = document.getElementById("three-line-twikoo");
		if (!host) return;
		host.innerHTML = "";
		twikoo
			.init({
				...twikooConfig,
				el: "#three-line-twikoo",
				path: "/three-line-poem",
			})
			.catch((error) => {
				console.error("[ThreeLinePoem] Twikoo 初始化失败", error);
			});
	}

	document.addEventListener("DOMContentLoaded", initThreeLineTwikoo);
	if (window.swup?.hooks) {
		window.swup.hooks.on("content:replace", () => {
			setTimeout(initThreeLineTwikoo, 200);
		});
	}
</script>

<style>
	.three-line-poem-activity {
		position: relative;
		overflow: hidden;
		padding: clamp(1.2rem, 2vw, 2rem);
		border: 1px solid rgba(216, 180, 254, 0.16);
		border-radius: 2rem;
		background:
			radial-gradient(circle at top left, rgba(196, 181, 253, 0.2) 0, transparent 26%),
			radial-gradient(circle at 88% 12%, rgba(125, 211, 252, 0.16) 0, transparent 22%),
			radial-gradient(circle at 50% 100%, rgba(244, 114, 182, 0.12) 0, transparent 28%),
			linear-gradient(145deg, rgba(255, 255, 255, 0.24) 0%, rgba(196, 181, 253, 0.14) 34%, rgba(125, 211, 252, 0.12) 62%, rgba(255, 255, 255, 0.22) 100%);
		box-shadow:
			0 36px 90px rgba(56, 34, 110, 0.16),
			inset 0 1px 0 rgba(255, 255, 255, 0.42),
			inset 0 -1px 0 rgba(191, 219, 254, 0.14);
		backdrop-filter: blur(24px) saturate(135%);
		isolation: isolate;
	}

	.activity-liquid {
		position: absolute;
		z-index: -1;
		border-radius: 999px;
		filter: blur(12px);
		opacity: 0.9;
	}

	.activity-liquid-a {
		width: 18rem;
		height: 8rem;
		top: 8%;
		right: -4rem;
		background: linear-gradient(135deg, rgba(196, 181, 253, 0.26), rgba(125, 211, 252, 0.1));
		transform: rotate(-12deg);
	}

	.activity-liquid-b {
		width: 15rem;
		height: 7rem;
		bottom: 12%;
		left: -3rem;
		background: linear-gradient(135deg, rgba(125, 211, 252, 0.16), rgba(244, 114, 182, 0.1));
		transform: rotate(10deg);
	}

	.activity-liquid-c {
		width: 10rem;
		height: 10rem;
		top: 35%;
		right: 18%;
		background: radial-gradient(circle, rgba(255, 255, 255, 0.22), rgba(196, 181, 253, 0.1), transparent 68%);
	}

	.activity-stars {
		position: absolute;
		inset: 0;
		background-image:
			radial-gradient(circle at 16% 20%, rgba(255, 255, 255, 0.82) 0 2px, transparent 2.5px),
			radial-gradient(circle at 76% 18%, rgba(255, 255, 255, 0.68) 0 1.5px, transparent 2px),
			radial-gradient(circle at 82% 42%, rgba(191, 219, 254, 0.48) 0 1.5px, transparent 2px),
			radial-gradient(circle at 34% 78%, rgba(255, 255, 255, 0.42) 0 1.5px, transparent 2px);
		opacity: 0.86;
		pointer-events: none;
	}

	.activity-orb {
		position: absolute;
		z-index: -1;
		border-radius: 999px;
		filter: blur(18px);
		opacity: 0.78;
	}

	.activity-orb-left {
		width: 12rem;
		height: 12rem;
		top: -4rem;
		left: -3rem;
		background: rgba(167, 139, 250, 0.28);
	}

	.activity-orb-center {
		width: 16rem;
		height: 16rem;
		top: 26%;
		left: 48%;
		transform: translate(-50%, -50%);
		background: rgba(125, 211, 252, 0.14);
	}

	.activity-orb-right {
		width: 12rem;
		height: 12rem;
		bottom: 1rem;
		right: -2rem;
		background: rgba(244, 114, 182, 0.18);
	}

	.glass-panel {
		border: 1px solid rgba(216, 180, 254, 0.16);
		background: linear-gradient(135deg, rgba(255, 255, 255, 0.18), rgba(196, 181, 253, 0.08), rgba(125, 211, 252, 0.08));
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.2),
			0 24px 46px rgba(56, 34, 110, 0.1);
		backdrop-filter: blur(18px) saturate(128%);
	}

	.activity-header {
		position: relative;
		padding: 0.35rem 0 0;
	}

	.activity-eyebrow {
		display: inline-flex;
		align-items: center;
		margin: 0;
		padding: 0.44rem 0.82rem;
		border: 1px solid rgba(216, 180, 254, 0.28);
		border-radius: 999px;
		background: linear-gradient(135deg, rgba(167, 139, 250, 0.22), rgba(125, 211, 252, 0.12));
		color: color-mix(in oklab, white 20%, var(--primary) 80%);
		font-size: 0.82rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		backdrop-filter: blur(10px);
	}

	.activity-header h1 {
		margin: 0.9rem 0 0.78rem;
		font-size: clamp(2.2rem, 5vw, 4rem);
		line-height: 1.03;
		letter-spacing: 0.04em;
		text-shadow: 0 12px 32px rgba(40, 21, 94, 0.18);
	}

	.activity-lead,
	.activity-subline {
		max-width: 60rem;
		margin: 0;
		line-height: 2;
		font-size: 1.02rem;
		color: color-mix(in oklab, var(--text-normal) 92%, white 8%);
	}

	.activity-subline {
		margin-top: 0.72rem;
		color: color-mix(in oklab, var(--text-normal) 72%, rgb(147 197 253) 28%);
	}

	.activity-note,
	.activity-scene,
	.activity-ending {
		position: relative;
		margin-top: 1.2rem;
		padding: 1.05rem 1.15rem;
		border-radius: 1.4rem;
	}

	.activity-note p,
	.activity-ending p {
		margin: 0;
		line-height: 1.95;
		font-size: 1rem;
	}

	.activity-scene {
		display: grid;
		gap: 0.85rem;
	}

	.scene-line-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.8rem;
	}

	.scene-line-grid span,
	.scene-quote {
		padding: 0.8rem 0.95rem;
		border-radius: 1rem;
		background: linear-gradient(135deg, rgba(255, 255, 255, 0.18), rgba(196, 181, 253, 0.08), rgba(125, 211, 252, 0.08));
		border: 1px solid rgba(216, 180, 254, 0.18);
		line-height: 1.75;
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.18);
	}

	.scene-quote {
		display: inline-flex;
		width: fit-content;
		font-size: 0.92rem;
		color: color-mix(in oklab, var(--text-normal) 75%, var(--primary) 25%);
	}

	.scene-quote-right {
		justify-self: end;
	}

	.activity-board {
		position: relative;
		margin-top: 1.3rem;
	}

	.board-head {
		margin-bottom: 1rem;
	}

	.board-heading {
		padding: 0.2rem 0.1rem 0;
	}

	.board-kicker {
		margin: 0;
		font-size: 0.82rem;
		font-weight: 800;
		letter-spacing: 0.12em;
		color: color-mix(in oklab, rgb(191 219 254) 36%, var(--primary) 64%);
	}

	.board-title {
		margin: 0.5rem 0 0;
		font-size: clamp(1.5rem, 2vw, 2.1rem);
		font-weight: 800;
	}

	.board-description {
		max-width: 52rem;
		margin: 0.68rem 0 0;
		line-height: 1.95;
		color: color-mix(in oklab, var(--text-normal) 84%, white 16%);
	}

	.board-shell {
		position: relative;
		padding: clamp(1rem, 1.8vw, 1.35rem);
		border: 1px solid rgba(191, 219, 254, 0.2);
		border-radius: 1.9rem;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.22), rgba(196, 181, 253, 0.1), rgba(125, 211, 252, 0.08)),
			radial-gradient(circle at top, rgba(255, 255, 255, 0.26), transparent 62%);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.2),
			0 30px 70px rgba(56, 34, 110, 0.12);
		backdrop-filter: blur(22px) saturate(135%);
	}

	.board-shell-glow,
	.board-shell-highlight,
	.board-shell-blur {
		position: absolute;
		inset: 0;
		border-radius: inherit;
		pointer-events: none;
	}

	.board-shell-glow {
		background: linear-gradient(135deg, rgba(191, 219, 254, 0.18), transparent 35%, rgba(244, 114, 182, 0.15));
	}

	.board-shell-highlight {
		inset: 1px;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0.02) 26%, transparent 46%);
	}

	.board-shell-blur {
		inset: auto 8% 8% auto;
		width: 10rem;
		height: 10rem;
		background: radial-gradient(circle, rgba(125, 211, 252, 0.14), transparent 70%);
		filter: blur(8px);
	}

	.twikoo-host {
		position: relative;
		padding: 0.5rem;
		border-radius: 1.3rem;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.18), rgba(196, 181, 253, 0.08), rgba(125, 211, 252, 0.06));
	}

	.twikoo-host :global(.tk-comments-container) {
		margin-top: 1.2rem;
		padding-top: 1.1rem;
		border-top: 1px solid rgba(216, 180, 254, 0.18);
	}

	.twikoo-host :global(.tk-comments-title) {
		margin-bottom: 0.95rem;
	}

	.twikoo-host :global(.tk-submit) {
		padding: 1rem;
		border: 1px solid rgba(216, 180, 254, 0.18);
		border-radius: 1.25rem;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.22), rgba(196, 181, 253, 0.08), rgba(125, 211, 252, 0.08));
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.22),
			0 18px 38px rgba(56, 34, 110, 0.08);
	}

	.twikoo-host :global(.tk-row.actions) {
		margin-top: 0.95rem;
		padding-top: 0.95rem;
		border-top: 1px dashed rgba(216, 180, 254, 0.2);
	}

	.twikoo-host :global(.tk-meta-input) {
		gap: 0.75rem;
	}

	.twikoo-host :global(.tk-avatar),
	.twikoo-host :global(.tk-avatar img) {
		border-radius: 1rem;
	}

	.twikoo-host :global(.tk-input),
	.twikoo-host :global(.el-input__inner),
	.twikoo-host :global(.el-textarea__inner) {
		border-radius: 1rem !important;
		border-color: rgba(191, 219, 254, 0.18) !important;
		background: rgba(255, 255, 255, 0.9) !important;
		box-shadow: none !important;
		transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
	}

	.twikoo-host :global(.el-input__inner),
	.twikoo-host :global(.el-textarea__inner) {
		padding: 0.9rem 1rem !important;
	}

	.twikoo-host :global(.tk-input:focus),
	.twikoo-host :global(.el-input__inner:focus),
	.twikoo-host :global(.el-textarea__inner:focus) {
		border-color: rgba(147, 197, 253, 0.38) !important;
		box-shadow: 0 0 0 4px rgba(167, 139, 250, 0.12) !important;
		transform: translateY(-1px);
	}

	.twikoo-host :global(.tk-preview-container),
	.twikoo-host :global(.tk-comment) {
		border: 1px solid rgba(216, 180, 254, 0.16);
		border-radius: 1.15rem;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.24), rgba(196, 181, 253, 0.08), rgba(125, 211, 252, 0.08));
		box-shadow: 0 18px 36px rgba(56, 34, 110, 0.08);
	}

	.twikoo-host :global(.tk-comment) {
		margin-bottom: 0.95rem;
		padding: 0.95rem 1rem;
	}

	.twikoo-host :global(.tk-comment .tk-content) {
		line-height: 1.92;
		font-size: 0.99rem;
	}

	.twikoo-host :global(.tk-tag),
	.twikoo-host :global(.tk-action-icon),
	.twikoo-host :global(.tk-comments-title > span),
	.twikoo-host :global(.tk-icon.__comments) {
		color: color-mix(in oklab, rgb(191 219 254) 24%, var(--text-normal) 76%);
	}

	.twikoo-host :global(.tk-extras),
	.twikoo-host :global(.tk-meta) {
		opacity: 0.84;
	}

	.twikoo-host :global(.el-button),
	.twikoo-host :global(.tk-submit-action-icon.__submit),
	.twikoo-host :global(.tk-preview) {
		border-radius: 999px !important;
		border: none !important;
		background: linear-gradient(135deg, rgba(147, 197, 253, 0.85), rgba(167, 139, 250, 0.95), rgba(244, 114, 182, 0.8)) !important;
		color: white !important;
		box-shadow: 0 16px 30px rgba(56, 34, 110, 0.18);
	}

	.twikoo-host :global(.tk-replies) {
		margin-top: 0.85rem;
		padding-left: 0.8rem;
		border-left: 1px solid rgba(216, 180, 254, 0.16);
	}

	.twikoo-host :global(.tk-replies .tk-comment) {
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.2), rgba(191, 219, 254, 0.08), rgba(196, 181, 253, 0.06));
	}

	@media (max-width: 768px) {
		.three-line-poem-activity {
			padding: 1rem;
			border-radius: 1.5rem;
		}

		.activity-header h1 {
			font-size: clamp(1.95rem, 10vw, 2.9rem);
		}

		.activity-lead,
		.activity-subline,
		.activity-note p,
		.board-description,
		.scene-line-grid span,
		.activity-ending p {
			font-size: 0.96rem;
		}

		.scene-line-grid {
			grid-template-columns: 1fr;
		}

		.scene-quote-right {
			justify-self: start;
		}

		.board-shell {
			padding: 0.8rem;
			border-radius: 1.45rem;
		}
	}
</style>
